#!/bin/bash

# data directory for OpenList
DATA_DIR="${TRIM_PKGVAR}"
# start command
CMD="${TRIM_APPDEST}/bin/openlist server --data ${DATA_DIR}"
# admin panel command
ADMIN_CMD="${TRIM_APPDEST}/bin/openlist-manager"

status() {
    # Check if openlist server process exists
    if pgrep -f "openlist server.*--data.*${DATA_DIR}" > /dev/null 2>&1; then
        return 0
    fi
    return 1
}

start_process() {
    if status; then
        return 0
    fi

    ${CMD} &
    ${ADMIN_CMD} &

    return 0
}

stop_process() {
    # Stop openlist using its own stop command
    ${TRIM_APPDEST}/bin/openlist stop --data ${DATA_DIR} 2>/dev/null

    # Fallback: kill by process name if stop command fails
    sleep 1
    if status; then
        pkill -f "openlist-manager" 2>/dev/null
    fi

    return 0
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
