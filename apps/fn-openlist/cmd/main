#!/bin/bash

# data directory for OpenList
DATA_DIR="${TRIM_PKGVAR}"
# start command
CMD="${TRIM_APPDEST}/bin/openlist restart --data ${DATA_DIR}"

status() {
    # Check if openlist server process exists
    if pgrep -f "openlist" > /dev/null 2>&1; then
        return 0
    fi
    return 1
}

start_process() {
    if status; then
        return 0
    fi

    ${CMD} &

    return 0
}

stop_process() {
    # Stop openlist using its own stop command
    ${TRIM_APPDEST}/bin/openlist stop 2>/dev/null

    return 0
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
