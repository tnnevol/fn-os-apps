#!/bin/bash

PID_FILE="${TRIM_PKGVAR}/openlist.pid"
MGR_PID_FILE="${TRIM_PKGVAR}/mgr.pid"

# data directory for OpenList
DATA_DIR="${TRIM_PKGVAR}"
# start command
CMD="${TRIM_APPDEST}/server/openlist server --data ${DATA_DIR}"
# admin panel command
ADMIN_CMD="${TRIM_APPDEST}/server/openlist-manager"

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

start_process() {
    if status; then
        return 0
    fi

    bash -c "${CMD}" &
    printf "%s" "$!" > ${PID_FILE}

    bash -c "${ADMIN_CMD}" &
    printf "%s" "$!" > ${MGR_PID_FILE}

    return 0
}

stop_process() {
    if [ -r "${MGR_PID_FILE}" ]; then
        pid=$(head -n 1 "${MGR_PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            kill -TERM ${pid} 2>/dev/null
            sleep 1
            check_process "${pid}" && kill -KILL "${pid}" 2>/dev/null
        fi
        rm -f "${MGR_PID_FILE}"
    fi

    local stopped=false
    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            kill -TERM ${pid} 2>/dev/null

            local count=0
            while check_process "${pid}" && [ $count -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done

            if check_process "${pid}"; then
                kill -KILL "${pid}"
                sleep 1
            fi
            stopped=true
        fi
        rm -f "${PID_FILE}"
    fi

    # Fallback: kill by process name if PID file was missing
    if [ "${stopped}" = false ]; then
        pkill -f "openlist server" 2>/dev/null
    fi

    return 0
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
