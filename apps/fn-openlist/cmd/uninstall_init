#!/bin/bash

### This script is called before the user uninstalls the application.

# Stop OpenList gracefully
OPENLIST_BIN="${TRIM_APPDEST}/bin/openlist"
if [ -f "$OPENLIST_BIN" ]; then
    $OPENLIST_BIN stop --data "${TRIM_PKGVAR}" 2>/dev/null
fi

# Stop openlist-manager via process name
pkill -f "openlist-manager" 2>/dev/null

exit 0
