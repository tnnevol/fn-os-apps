#!/bin/bash

### This script is called after the application is installed.
### Download, extract OpenList binary.

set -e

BIN_DIR="${TRIM_APPDEST}/bin"

# Download and extract OpenList latest binary via pipe
OPENLIST_URL="https://gh-proxy.com/https://github.com/OpenListTeam/OpenList/releases/latest/download/openlist-linux-musl-amd64.tar.gz"

echo "Downloading OpenList latest..."

if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${OPENLIST_URL}" | tar -xz -C "${BIN_DIR}" openlist
elif command -v wget >/dev/null 2>&1; then
    wget -q -O - "${OPENLIST_URL}" | tar -xz -C "${BIN_DIR}" openlist
else
    echo "No curl or wget found, cannot download OpenList"
    exit 1
fi

chmod +x "${BIN_DIR}/openlist"
echo "OpenList installed to ${BIN_DIR}/openlist"

exit 0
