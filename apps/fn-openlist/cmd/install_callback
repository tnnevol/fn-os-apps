#!/bin/bash

### This script is called after the application is installed.
### Download, extract OpenList binary.

set -e

BIN_DIR="${TRIM_APPDEST}/bin"
DATA_DIR="${TRIM_PKGVAR}/data"

# Download and extract OpenList latest binary via pipe
OPENLIST_URL="https://gh-proxy.com/https://github.com/OpenListTeam/OpenList/releases/latest/download/openlist-linux-musl-amd64.tar.gz"

echo "Downloading OpenList latest..."

if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${OPENLIST_URL}" | tar -xz -C "${BIN_DIR}" openlist
elif command -v wget >/dev/null 2>&1; then
    wget -q -O - "${OPENLIST_URL}" | tar -xz -C "${BIN_DIR}" openlist
else
    echo "No curl or wget found, cannot download OpenList"
    exit 1
fi

chmod +x "${BIN_DIR}/openlist"
echo "OpenList installed to ${BIN_DIR}/openlist"

# Copy default config to data directory
echo "DEBUG: TRIM_APPDEST=${TRIM_APPDEST}, DATA_DIR=${DATA_DIR}"
echo "DEBUG: TRIM_PKGVAR=${TRIM_PKGVAR}, wizard_port=${wizard_port}"
mkdir -p "${DATA_DIR}"
echo "DEBUG: DATA_DIR created at ${DATA_DIR}"
if [ -f "${TRIM_APPDEST}/temp/config.json" ]; then
    echo "DEBUG: Found config template at ${TRIM_APPDEST}/temp/config.json"
    cp "${TRIM_APPDEST}/temp/config.json" "${DATA_DIR}/config.json"
    echo "DEBUG: Copied config.json to ${DATA_DIR}/config.json"
    # Replace environment variable placeholders with real values
    echo "DEBUG: Replacing \${TRIM_PKGVAR} with ${TRIM_PKGVAR}"
    sed -i "s|\${TRIM_PKGVAR}|${TRIM_PKGVAR}|g" "${DATA_DIR}/config.json"
    # wizard_port should be a number, not a string — remove surrounding quotes
    echo "DEBUG: Replacing http_port string with number: ${wizard_port}"
    sed -i "s|\"http_port\": \"[0-9]*\"|\"http_port\": ${wizard_port}|g" "${DATA_DIR}/config.json"
    echo "DEBUG: Final config content:"
    cat "${DATA_DIR}/config.json"
    echo "Default config copied to ${DATA_DIR}/config.json"
else
    echo "DEBUG: Config template NOT found at ${TRIM_APPDEST}/temp/config.json"
fi

exit 0
