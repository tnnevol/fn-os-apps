#!/bin/bash

### This script is called before the user installs the application.

set -e

APP_DIR="${TRIM_APPDEST}"
BIN_DIR="${APP_DIR}/server"

# Create binary directory
mkdir -p "${BIN_DIR}"

# Download OpenList latest binary
OPENLIST_URL="https://github.com/OpenListTeam/OpenList/releases/latest/download/openlist-linux-amd64.tar.gz"
TAR_FILE="${TRIM_PKGTMP}/openlist-latest.tar.gz"

echo "Downloading OpenList latest..."

if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "${TAR_FILE}" "${OPENLIST_URL}" || {
        echo "Primary URL failed, trying mirror..."
        OPENLIST_URL="https://gh-proxy.com/${OPENLIST_URL}"
        curl -fsSL -o "${TAR_FILE}" "${OPENLIST_URL}" || {
            echo "Failed to download OpenList from all sources"
            exit 1
        }
    }
elif command -v wget >/dev/null 2>&1; then
    wget -q -O "${TAR_FILE}" "${OPENLIST_URL}" || {
        echo "Primary URL failed, trying mirror..."
        OPENLIST_URL="https://gh-proxy.com/${OPENLIST_URL}"
        wget -q -O "${TAR_FILE}" "${OPENLIST_URL}" || {
            echo "Failed to download OpenList from all sources"
            exit 1
        }
    }
else
    echo "No curl or wget found, cannot download OpenList"
    exit 1
fi

echo "Extracting OpenList binary..."
tar -xzf "${TAR_FILE}" -C "${BIN_DIR}" openlist 2>/dev/null || {
    tar -xzf "${TAR_FILE}" -C "${BIN_DIR}" 2>/dev/null || {
        echo "Failed to extract OpenList archive"
        rm -f "${TAR_FILE}"
        exit 1
    }
}

# Clean up
rm -f "${TAR_FILE}"

# Make binary executable
chmod +x "${BIN_DIR}/openlist"

# Copy openlist-manager binary (bundled in fpk)
if [ -f "${TRIM_APPDEST}/app/server/openlist-manager" ]; then
    cp "${TRIM_APPDEST}/app/server/openlist-manager" "${BIN_DIR}/openlist-manager"
    chmod +x "${BIN_DIR}/openlist-manager"
    echo "OpenList manager installed to ${BIN_DIR}/openlist-manager"
fi

echo "OpenList latest installed to ${BIN_DIR}/openlist"
echo "OpenList installation completed"

exit 0
