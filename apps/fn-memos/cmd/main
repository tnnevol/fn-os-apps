#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

# Memos binary path
MEMOS_BIN="${TRIM_APPDEST}/bin/memos"
MEMOS_PORT="${wizard_port:-5230}"

# Build start command based on storage type
case "${wizard_storage_type}" in
    mysql)
        CMD="${MEMOS_BIN} --port ${MEMOS_PORT} --driver mysql --dsn \"${wizard_dsn}\""
        ;;
    postgres)
        CMD="${MEMOS_BIN} --port ${MEMOS_PORT} --driver postgres --dsn \"${wizard_dsn}\""
        ;;
    *)
        DATA_DIR="${TRIM_PKGVAR}/data"
        CMD="${MEMOS_BIN} --port ${MEMOS_PORT} --data ${DATA_DIR}"
        ;;
esac

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

start_process() {
    if status; then
        return 0
    fi

    log_msg "Starting Memos (storage: ${wizard_storage_type:-local}) ..."
    bash -c "${CMD}" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${PID_FILE}"
    log_msg "Memos started with pid $!"
    return 0
}

stop_process() {
    log_msg "Stopping Memos ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            log_msg "remove pid file"
            return
        fi

        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM ${pid} >> "${LOG_FILE}" 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/10s)"
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
        fi

        rm -f "${PID_FILE}"
    fi

    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi

    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
