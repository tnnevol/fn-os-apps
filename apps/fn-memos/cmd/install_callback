#!/bin/bash

### This script is called after the application is installed.
### Download Memos binary.

set -e

BIN_DIR="${TRIM_APPDEST}/bin"
mkdir -p "${BIN_DIR}" "${TRIM_PKGVAR}/data"

# Get latest version by scraping the GitHub releases page (avoids unauthenticated API rate limits)
LATEST_TAG=$(curl -fsSL "https://github.com/usememos/memos/releases/latest" \
    | grep -oP '/releases/tag/v\K[0-9]+\.[0-9]+\.[0-9]+' \
    | head -1)

if [ -z "${LATEST_TAG}" ]; then
    echo "Failed to resolve Memos latest version"
    exit 1
fi

echo "Memos latest version: ${LATEST_TAG}"

# Download Memos binary via gh-proxy mirror
MEMOS_URL="https://gh-proxy.com/https://github.com/usememos/memos/releases/latest/download/memos_${LATEST_TAG}_linux_amd64.tar.gz"

echo "Downloading Memos ${LATEST_TAG}..."

if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${MEMOS_URL}" | tar -xz -C "${BIN_DIR}" memos
elif command -v wget >/dev/null 2>&1; then
    wget -q -O - "${MEMOS_URL}" | tar -xz -C "${BIN_DIR}" memos
else
    echo "No curl or wget found, cannot download Memos"
    exit 1
fi

chmod +x "${BIN_DIR}/memos"
echo "Memos installed to ${BIN_DIR}/memos"

exit 0
